T5_MODEL_NAME=valhalla/t5-small-qg-hl
BERT_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=true

# Set to true to skip T5 model loading (useful if transformers/torch version
# causes crashes or OOM. Template-based question generation is used instead.)
DISABLE_T5_MODEL=false
